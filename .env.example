OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Local SQLite database. For now the backend supports SQLite URLs/paths.
DATABASE_URL=sqlite:///data/app/app.sqlite3

# Server-side auth/session settings.
APP_SECRET_KEY=change-this-before-production
ACCESS_TOKEN_TTL_MINUTES=480
PASSWORD_MIN_LENGTH=8

# Local default admin. Change these before packaging or deploying.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_FULL_NAME=Administrator
